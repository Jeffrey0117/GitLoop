# GitLoop Configuration

# Telegram Bot (required — for push notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# GitHub repos to monitor (comma-separated, leave empty to auto-discover)
GITHUB_REPOS=owner/repo1,owner/repo2

# Poll interval in seconds (default: 60)
GITHUB_POLL_INTERVAL=60

# AI code review (uses Claude CLI — zero API cost)
REVIEW_ENABLED=true

# Gitea (optional — for self-hosted git)
# GITEA_URL=http://localhost:3000
# GITEA_ADMIN_TOKEN=your_gitea_admin_token

# Server
PORT=4012
